{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "validate": "tsc --noEmit && eslint .",
    "electron:compile": "tsc electron/main.ts electron/preload.ts --outDir dist-electron --module commonjs --target es6 --esModuleInterop --skipLibCheck && echo '{\"type\": \"commonjs\"}' > dist-electron/package.json",
    "electron": "wait-on tcp:8081 && pnpm run electron:compile && cross-env VITE_DEV_SERVER_URL=http://localhost:8081 electron .",
    "electron:build": "tsc electron/main.ts electron/preload.ts --outDir dist-electron --module commonjs --target es6 && electron-builder",
    "electron:dev": "concurrently -k \"pnpm run dev\" \"pnpm run electron\""
  },
  "dependencies": {
